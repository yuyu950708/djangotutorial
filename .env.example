# 使用方式：複製此檔為專案根目錄的 `.env`，填入你的 資料庫帳密及 NVIDIA API 金鑰。

# --- 資料庫（MySQL / MariaDB）---
DB_ENGINE=django.db.backends.mysql
DB_NAME=eat_what
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=3308

# --- NVIDIA Integrate（美食助理 AI；專案中亦作為 GEMINI_API_KEY 的來源）---
NVIDIA_API_KEY=your_nvidia_api_key_here